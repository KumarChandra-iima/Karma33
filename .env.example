# Copy this file to .env.local and fill in real values. .env.local is
# gitignored - never commit actual credentials.
#
# VITE_-prefixed vars are bundled into the client-side JS bundle by Vite,
# so only ever put values here that are safe to expose publicly (the
# Supabase URL and the publishable/anon key are designed for this - see
# https://supabase.com/docs/guides/api/api-keys). Never put the database
# password or a service-role key behind a VITE_ prefix.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Used only by dev-control/scripts/run-supabase-migration.cjs to apply SQL
# migrations directly via psql/pg - never read by the app itself, never
# VITE_-prefixed, never committed.
SUPABASE_DB_PASSWORD=
